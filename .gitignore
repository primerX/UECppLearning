# Unreal Engine 5 .gitignore

# Compiled binaries / build output
Binaries/
DerivedDataCache/
Intermediate/
Saved/
Build/

# Visual Studio
.vs/
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Platforms
Platforms/

# Asset caches
*.VC.db
*.VC.opendb

# OS files
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# Crashpad
crashpad_handler.exe

# Large binary files in Content (optional: remove if you want to track uasset/umap)
# *.uasset
# *.umap
